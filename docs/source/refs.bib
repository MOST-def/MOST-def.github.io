@article{arslan2021,
  title = {Bounds for Internally Heated Convection with Fixed Boundary Heat Flux},
  author = {Arslan, Ali and Fantuzzi, Giovanni and Craske, John and Wynn, Andrew},
  year = 2021,
  month = sep,
  journal = {Journal of Fluid Mechanics},
  volume = {922},
  pages = {R1},
  issn = {0022-1120, 1469-7645},
  doi = {10.1017/jfm.2021.527},
  urldate = {2025-09-10},
  abstract = {, We prove a new rigorous bound for the mean convective heat transport {$\langle$}wT{$\rangle\backslash$}langle w T \textbackslash rangle, where ww and TT are the non-dimensional vertical velocity and temperature, in internally heated convection between an insulating lower boundary and an upper boundary with a fixed heat flux. The quantity {$\langle$}wT{$\rangle\backslash$}langle wT \textbackslash rangle is equal to half the ratio of convective to conductive vertical heat transport, and also to 12\textbackslash frac 12 plus the mean temperature difference between the top and bottom boundaries. An analytical application of the background method based on the construction of a quadratic auxiliary function yields {$\langle$}wT{$\rangle\leq$}12(12+13\textsurd )-1.6552R-(1/3)\textbackslash langle w T \textbackslash rangle \textbackslash leq \textbackslash frac \textbraceleft 1\textbraceright\textbraceleft 2\textbraceright (\textbackslash frac \textbraceleft 1\textbraceright\textbraceleft 2\textbraceright + \textbackslash frac \textbraceleft 1\textbraceright\textbraceleft\textbackslash sqrt \textbraceleft 3\textbraceright\textbraceright{} ) - 1.6552\textbackslash, \textbraceleft\textbackslash textit \textbraceleft R\textbraceright\textbraceright\textasciicircum\textbraceleft -(1/3)\textbraceright{} uniformly in the Prandtl number, where R is the non-dimensional control parameter measuring the strength of the internal heating. Numerical optimisation of the auxiliary function suggests that the asymptotic value of this bound and the -1/3-1/3 exponent are optimal within our bounding framework. This new result halves the best existing (uniform in R \textbraceleft\textbackslash textit \textbraceleft R\textbraceright\textbraceright ) bound (Goluskin, Internally Heated Convection and Rayleigh--B\'enard Convection, Springer, 2016, table 1.2), and its dependence on R \textbraceleft\textbackslash textit \textbraceleft R\textbraceright\textbraceright{} is consistent with previous conjectures and heuristic scaling arguments. Contrary to physical intuition, however, it does not rule out a mean heat transport larger than 12\textbackslash frac 12 at high R \textbraceleft\textbackslash textit \textbraceleft R\textbraceright\textbraceright, which corresponds to the top boundary being hotter than the bottom one on average.},
  langid = {english},
  keywords = {MOST_def_refs,variational methods},
  file = {/home/jc707/.zotero/zotero/4axsgs60.default/zotero/storage/429Q2RVS/Arslan et al. - 2021 - Bounds for internally heated convection with fixed boundary heat flux.pdf}
}

